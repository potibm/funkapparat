#!/usr/bin/env bash
#MISE description="Setup Docker buildx builder (Internal)"
#MISE hide=true

set -e 

if ! docker buildx inspect funkapparat-builder >/dev/null 2>&1; then
    echo "🔧 Creating buildx builder 'funkapparat-builder'..."
    docker buildx create --name funkapparat-builder --use --bootstrap
else
    echo "✅ Using existing buildx builder 'funkapparat-builder'"
    docker buildx use funkapparat-builder
    docker buildx inspect --bootstrap > /dev/null
fi